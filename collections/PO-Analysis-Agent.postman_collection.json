{
  "info": {
    "_postman_id": "f3a1b2c4-d5e6-7890-a1b2-c3d4e5f60001",
    "name": "PO Analysis Agent",
    "description": "Collection for the PO Analysis Agent — a CAP (Node.js) service that performs AI-assisted 3-way matching of Purchase Orders, Goods Receipts, and Invoices.\n\n**Setup**\n1. Copy `.env.example` → `.env`\n2. Set `AI_PROVIDER=claude` and add your `ANTHROPIC_API_KEY` (or keep `AI_PROVIDER=mock` for offline testing)\n3. Run `cds watch` — server starts on port 4004\n4. Import this collection in Postman and hit any request\n\n**Service base:** `http://localhost:4004/api/po-analysis`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4004",
      "type": "string",
      "description": "Base URL of the running CAP server"
    },
    {
      "key": "resultID",
      "value": "",
      "type": "string",
      "description": "UUID of an AnalysisResult — auto-populated by the 'List Analysis Results' test script. Run that request after triggerAnalysis, then use markReviewed."
    }
  ],
  "item": [
    {
      "name": "Entities (OData)",
      "description": "OData v4 read operations on the four service entities. Supports standard query options: $filter, $select, $expand, $orderby, $top, $skip.",
      "item": [
        {
          "name": "List all Purchase Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/po-analysis/PurchaseOrders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "po-analysis", "PurchaseOrders"]
            }
          }
        },
        {
          "name": "Get PO — Clean (po-001)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/po-analysis/PurchaseOrders('11111111-1111-1111-1111-111111111001')",
              "host": ["{{baseUrl}}"],
              "path": ["api", "po-analysis", "PurchaseOrders('11111111-1111-1111-1111-111111111001')"]
            },
            "description": "Acme Industrial Supplies — GR and invoice match the ordered amount and quantity exactly. Expect a CLEAN result when triggerAnalysis is called."
          }
        },
        {
          "name": "Get PO — Conflict with Contextual Notes (po-010)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/po-analysis/PurchaseOrders('11111111-1111-1111-1111-111111111010')",
              "host": ["{{baseUrl}}"],
              "path": ["api", "po-analysis", "PurchaseOrders('11111111-1111-1111-1111-111111111010')"]
            },
            "description": "Caledonian Engineering — quantity conflict that is explained by free-text notes on the PO (partial delivery agreed with vendor). The AI lowers its confidence score to reflect the context."
          }
        },
        {
          "name": "List all Goods Receipts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/po-analysis/GoodsReceipts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "po-analysis", "GoodsReceipts"]
            }
          }
        },
        {
          "name": "List all Invoices",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/po-analysis/Invoices",
              "host": ["{{baseUrl}}"],
              "path": ["api", "po-analysis", "Invoices"]
            }
          }
        },
        {
          "name": "List Analysis Results",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/po-analysis/AnalysisResults",
              "host": ["{{baseUrl}}"],
              "path": ["api", "po-analysis", "AnalysisResults"]
            },
            "description": "Returns all AI analysis results. Run this after triggerAnalysis to inspect assessments, confidence scores, and recommendations. The test script auto-sets {{resultID}} to the first result's ID."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "const results = json.value || [];",
                  "if (results.length > 0) {",
                  "    pm.collectionVariables.set('resultID', results[0].ID);",
                  "    console.log('resultID set to:', results[0].ID);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Filter — Analysis Results for a PO",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/po-analysis/AnalysisResults?$filter=poID_ID eq '11111111-1111-1111-1111-111111111004'&$orderby=poID_ID",
              "host": ["{{baseUrl}}"],
              "path": ["api", "po-analysis", "AnalysisResults"],
              "query": [
                { "key": "$filter", "value": "poID_ID eq '11111111-1111-1111-1111-111111111004'" },
                { "key": "$orderby", "value": "poID_ID" }
              ]
            },
            "description": "OData $filter example — scope results to a single PO. Change 'po-004' to any PO ID."
          }
        }
      ]
    },
    {
      "name": "Actions",
      "description": "OData v4 actions that trigger AI analysis and workflow transitions.",
      "item": [
        {
          "name": "Trigger Analysis — Clean (po-001)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"poID\": \"11111111-1111-1111-1111-111111111001\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/po-analysis/triggerAnalysis",
              "host": ["{{baseUrl}}"],
              "path": ["api", "po-analysis", "triggerAnalysis"]
            },
            "description": "Acme Industrial Supplies — all figures match. Expect 0 conflicts and a CLEAN assessment."
          }
        },
        {
          "name": "Trigger Analysis — Amount Conflict (po-004)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"poID\": \"11111111-1111-1111-1111-111111111004\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/po-analysis/triggerAnalysis",
              "host": ["{{baseUrl}}"],
              "path": ["api", "po-analysis", "triggerAnalysis"]
            },
            "description": "Alpine Precision Parts AG — Invoice (9920 EUR) exceeds GR and PO amount (9750 EUR). Expect AMOUNT_MISMATCH and an AI recommendation to hold payment pending vendor clarification."
          }
        },
        {
          "name": "Trigger Analysis — Amount Conflict (po-005)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"poID\": \"11111111-1111-1111-1111-111111111005\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/po-analysis/triggerAnalysis",
              "host": ["{{baseUrl}}"],
              "path": ["api", "po-analysis", "triggerAnalysis"]
            },
            "description": "Baltic Freight Carriers — Invoice (6930 EUR) exceeds GR amount (6600 EUR). No notes on the PO, so the AI should flag this with high confidence."
          }
        },
        {
          "name": "Trigger Analysis — Quantity + Amount Conflict (po-009)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"poID\": \"11111111-1111-1111-1111-111111111009\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/po-analysis/triggerAnalysis",
              "host": ["{{baseUrl}}"],
              "path": ["api", "po-analysis", "triggerAnalysis"]
            },
            "description": "Levantine Textiles — GR quantity (190) short vs PO (250) and invoice amount (11250) does not match the GR (8550). Expect multiple conflicts in a single analysis."
          }
        },
        {
          "name": "Trigger Analysis — Conflict Explained by Notes (po-010)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"poID\": \"11111111-1111-1111-1111-111111111010\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/po-analysis/triggerAnalysis",
              "host": ["{{baseUrl}}"],
              "path": ["api", "po-analysis", "triggerAnalysis"]
            },
            "description": "Caledonian Engineering — partial delivery conflict (GR qty 90 vs PO qty 120) but the PO notes explain it. The AI should reflect the context with a lower confidence score compared to po-009."
          }
        },
        {
          "name": "Trigger Analysis — Missing GR & Invoice (po-007)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"poID\": \"11111111-1111-1111-1111-111111111007\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/po-analysis/triggerAnalysis",
              "host": ["{{baseUrl}}"],
              "path": ["api", "po-analysis", "triggerAnalysis"]
            },
            "description": "Benelux Tech Components — no GR or Invoice exists for this PO. Expect MISSING_GR and MISSING_INVOICE conflicts."
          }
        },
        {
          "name": "Run Full Analysis (All POs)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/po-analysis/runFullAnalysis",
              "host": ["{{baseUrl}}"],
              "path": ["api", "po-analysis", "runFullAnalysis"]
            },
            "description": "Batch action that mirrors the daily scheduled job — analyses all OPEN Purchase Orders and persists results in one call."
          }
        },
        {
          "name": "Mark Result as Reviewed",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resultID\": \"{{resultID}}\",\n  \"reviewedBy\": \"Your Name\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/po-analysis/markReviewed",
              "host": ["{{baseUrl}}"],
              "path": ["api", "po-analysis", "markReviewed"]
            },
            "description": "Marks an AnalysisResult as reviewed by a named AP reviewer. {{resultID}} is auto-set when you run 'List Analysis Results' — or paste a UUID manually."
          }
        }
      ]
    }
  ]
}
