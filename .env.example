# ── AI Provider ───────────────────────────────────────────────────────────────
# Select which AI backend to use.
# Values: mock | claude | aicore
# Default: mock (no external calls, suitable for local development and CI)
AI_PROVIDER=mock

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Required when AI_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-...

# ── SAP AI Core ───────────────────────────────────────────────────────────────
# Required when AI_PROVIDER=aicore
AICORE_BASE_URL=https://<your-aicore-instance>.inference.ml.hana.ondemand.com
AICORE_AUTH_URL=https://<your-uaa-subdomain>.authentication.eu10.hana.ondemand.com/oauth/token
AICORE_CLIENT_ID=sb-your-client-id
AICORE_CLIENT_SECRET=your-client-secret
AICORE_DEPLOYMENT_ID=d1234abcd
AICORE_RESOURCE_GROUP=default

# ── SAP HANA (production only) ────────────────────────────────────────────────
# In local development, CAP uses an in-memory SQLite DB automatically.
# On SAP BTP, credentials are injected via VCAP_SERVICES — do not set these manually.
# VCAP_SERVICES=...

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4004
